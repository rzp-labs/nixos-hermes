+NIX_SOURCE = b'''{ config, lib, pkgs, ... }:
+
+let
+  cfg = config.services.agentmemory;
+  startScript = pkgs.writeShellScript "agentmemory-start" ''
+    exec ${pkgs.nodejs}/bin/node ${cfg.package}/dist/index.mjs
+  '';
+in
+{
+  imports = [
+    ./hardware.nix
+    ../../modules/hermes-agent.nix
+  ];
+
+  services.agentmemory.enable = lib.mkDefault true;
+  systemd.services.agentmemory.serviceConfig.ExecStart = startScript;
+  configFile = import ./config.nix;
+}
+'''
+
+
+pytest.importorskip("tree_sitter_nix", reason="run `uv sync --all-packages`")
+
+
+class TestNixParser:
+    def test_finds_attr_binding_symbols(self, parser: ASTParser) -> None:
+        fi = _make_file_info("hosts/hermes/agentmemory.nix", "nix")
+        result = parser.parse_file(fi, NIX_SOURCE)
+        names = {s.name for s in result.symbols}
+        assert "cfg" in names
+        assert "services.agentmemory.enable" in names
+        assert "systemd.services.agentmemory.serviceConfig.ExecStart" in names
+
+    def test_parses_module_and_direct_imports(self, parser: ASTParser) -> None:
+        fi = _make_file_info("hosts/hermes/agentmemory.nix", "nix")
+        result = parser.parse_file(fi, NIX_SOURCE)
+        modules = [i.module_path for i in result.imports]
+        assert "./hardware.nix" in modules
+        assert "../../modules/hermes-agent.nix" in modules
+        assert "./config.nix" in modules
+        assert all(i.is_relative for i in result.imports)
+
+    def test_extracts_coarse_call_targets(self, parser: ASTParser) -> None:
+        fi = _make_file_info("hosts/hermes/agentmemory.nix", "nix")
+        result = parser.parse_file(fi, NIX_SOURCE)
+        targets = {c.target_name for c in result.calls}
+        assert "pkgs.writeShellScript" in targets
+        assert "lib.mkDefault" in targets
