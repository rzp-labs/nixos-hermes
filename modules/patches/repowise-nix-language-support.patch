diff --git a/packages/core/src/repowise/core/ingestion/resolvers/nix.py b/packages/core/src/repowise/core/ingestion/resolvers/nix.py
new file mode 100644
index 0000000..355d22b
--- /dev/null
+++ b/packages/core/src/repowise/core/ingestion/resolvers/nix.py
@@ -0,0 +1,41 @@
+"""Nix import resolution for relative module paths."""
+
+from __future__ import annotations
+
+from pathlib import PurePosixPath
+import posixpath
+
+from .context import ResolverContext
+from .generic import resolve_generic_import
+
+
+def resolve_nix_import(
+    module_path: str, importer_path: str, ctx: ResolverContext
+) -> str | None:
+    """Resolve common Nix path imports.
+
+    NixOS modules most often import relative paths such as ``./hardware.nix`` or
+    ``../../modules/users.nix``. Directory imports conventionally resolve to a
+    ``default.nix`` below that directory. For non-path module strings, fall back
+    to Repowise's generic stem resolver.
+    """
+    module_path = module_path.strip().strip('"\'` ')
+    if not module_path:
+        return None
+
+    if module_path.startswith("./") or module_path.startswith("../"):
+        base = PurePosixPath(importer_path).parent
+        target = base.joinpath(PurePosixPath(module_path))
+        normalized = posixpath.normpath(target.as_posix())
+
+        candidates = [normalized]
+        if not normalized.endswith(".nix"):
+            candidates.append(f"{normalized}.nix")
+            candidates.append(f"{normalized}/default.nix")
+
+        for candidate in candidates:
+            collapsed = posixpath.normpath(candidate)
+            if collapsed in ctx.path_set:
+                return collapsed
+
+    return resolve_generic_import(module_path, importer_path, ctx)
