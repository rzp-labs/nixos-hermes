diff --git a/packages/core/src/repowise/core/ingestion/queries/nix.scm b/packages/core/src/repowise/core/ingestion/queries/nix.scm
new file mode 100644
index 0000000..68889aa
--- /dev/null
+++ b/packages/core/src/repowise/core/ingestion/queries/nix.scm
@@ -0,0 +1,36 @@
+; =============================================================================
+; repowise — Nix symbol and import queries
+;
+; Minimal support targets first-order structure, not full Nix evaluation:
+; module function heads, attr bindings, imports lists, direct path imports, and
+; coarse application/call sites.
+; =============================================================================
+
+; Attribute bindings are the closest useful first-order symbol for NixOS modules:
+; services.foo.enable, systemd.services.bar, flake inputs, let bindings, etc.
+(binding
+  attrpath: (attrpath) @symbol.name
+) @symbol.def
+
+; NixOS module imports = [ ./x.nix ../y.nix ].
+(binding
+  attrpath: (attrpath (identifier) @import.attr)
+  expression: (list_expression
+    (path_expression (path_fragment) @import.module))
+  (#eq? @import.attr "imports")
+) @import.statement
+
+; Direct path imports: import ./x.nix
+(apply_expression
+  function: (variable_expression (identifier) @call.target)
+  argument: (path_expression (path_fragment) @import.module)
+  (#eq? @call.target "import")
+) @import.statement
+
+; Coarse Nix function/application calls.
+(apply_expression
+  function: [
+    (variable_expression (identifier) @call.target)
+    (select_expression) @call.target
+  ]
+) @call.site
