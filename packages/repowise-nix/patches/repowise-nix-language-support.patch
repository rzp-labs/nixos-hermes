diff -ruN a/packages/core/src/repowise/core/ingestion/resolvers/nix.py b/packages/core/src/repowise/core/ingestion/resolvers/nix.py
--- a/packages/core/src/repowise/core/ingestion/resolvers/nix.py	1969-12-31 17:00:00.000000000 -0700
+++ b/packages/core/src/repowise/core/ingestion/resolvers/nix.py	2026-05-29 01:06:15.727745160 -0700
@@ -0,0 +1,66 @@
+"""Static Nix path-edge resolution.
+
+This resolver intentionally does not run ``nix``. It covers the common
+evaluator-shaped path edges Repowise can infer safely from syntax: direct
+imports, module import lists, selected path-bearing applications such as
+``callPackage`` / ``evalModule``, and local ``path:`` flake inputs.
+"""
+
+from __future__ import annotations
+
+from pathlib import PurePosixPath
+import posixpath
+
+from .context import ResolverContext
+from .generic import resolve_generic_import
+
+
+def _normalize_relative_path(module_path: str, importer_path: str) -> str | None:
+    if module_path.startswith("path:"):
+        module_path = module_path.removeprefix("path:")
+    module_path = module_path.strip().strip('"\'` ')
+    if not (module_path.startswith("./") or module_path.startswith("../")):
+        return None
+    base = PurePosixPath(importer_path).parent
+    target = base.joinpath(PurePosixPath(module_path))
+    return posixpath.normpath(target.as_posix())
+
+
+def _candidate_paths(normalized: str, *, prefer_flake: bool = False) -> list[str]:
+    candidates = [normalized]
+    if normalized.endswith(".nix"):
+        return candidates
+
+    dir_candidates = [f"{normalized}.nix", f"{normalized}/default.nix"]
+    flake_candidate = f"{normalized}/flake.nix"
+    if prefer_flake:
+        candidates.extend([flake_candidate, *dir_candidates])
+    else:
+        candidates.extend([*dir_candidates, flake_candidate])
+    return candidates
+
+
+def resolve_nix_import(
+    module_path: str, importer_path: str, ctx: ResolverContext
+) -> str | None:
+    """Resolve common static Nix path references.
+
+    Directory/path resolution is deterministic: explicit file, ``foo.nix``,
+    ``foo/default.nix``, then ``foo/flake.nix``. Local flake inputs prefer
+    nested ``flake.nix``. Unsupported dynamic/non-path expressions fall back
+    to generic resolution rather than claiming a high-confidence edge.
+    """
+    module_path = module_path.strip().strip('"\'` ')
+    if not module_path:
+        return None
+
+    prefer_flake = module_path.startswith("path:")
+    normalized = _normalize_relative_path(module_path, importer_path)
+    if normalized is not None:
+        for candidate in _candidate_paths(normalized, prefer_flake=prefer_flake):
+            collapsed = posixpath.normpath(candidate)
+            if collapsed in ctx.path_set:
+                return collapsed
+        return None
+
+    return resolve_generic_import(module_path, importer_path, ctx)
