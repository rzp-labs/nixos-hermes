+def test_nix_infra_root_with_graph_signal_not_unreachable():
+    """Nix infra files with evaluator-shaped graph signals are not safe deletions."""
+    graph = nx.DiGraph()
+    graph.add_nodes_from(
+        [
+            ("flake.nix", {"language": "nix", "is_entry_point": True, "symbol_count": 1, "symbols": [], "is_nix_infra_root": True}),
+            ("packages/tool/default.nix", {"language": "nix", "is_entry_point": False, "symbol_count": 1, "symbols": [], "is_nix_infra_root": True}),
+        ]
+    )
+    graph.add_edge("flake.nix", "packages/tool/default.nix", edge_type="imports")
+
+    analyzer = DeadCodeAnalyzer(graph, git_meta_map={})
+    report = analyzer.analyze({"detect_unused_exports": False, "detect_zombie_packages": False})
+
+    paths = {f.file_path for f in report.findings if f.kind.value == "unreachable_file"}
+    assert "packages/tool/default.nix" not in paths
+
+
+def test_nix_infra_zombie_package_suppressed_when_signaled():
+    graph = nx.DiGraph()
+    graph.add_nodes_from(
+        [
+            ("flake.nix", {"language": "nix", "is_entry_point": True, "symbol_count": 1, "symbols": [], "is_nix_infra_root": True}),
+            ("packages/tool/default.nix", {"language": "nix", "is_entry_point": False, "symbol_count": 1, "symbols": [], "is_nix_infra_root": True}),
+            ("src/main.py", {"language": "python", "is_entry_point": True, "symbol_count": 1, "symbols": []}),
+        ]
+    )
+    graph.add_edge("flake.nix", "packages/tool/default.nix", edge_type="imports")
+
+    analyzer = DeadCodeAnalyzer(graph, git_meta_map={})
+    report = analyzer.analyze({"detect_unreachable_files": False, "detect_unused_exports": False})
+
+    paths = {f.file_path for f in report.findings if f.kind.value == "zombie_package"}
+    assert "packages" not in paths
+
+
+def test_real_unreachable_nix_file_remains_reportable():
+    graph = nx.DiGraph()
+    graph.add_nodes_from(
+        [
+            ("flake.nix", {"language": "nix", "is_entry_point": True, "symbol_count": 1, "symbols": [], "is_nix_infra_root": True}),
+            ("unused/dead.nix", {"language": "nix", "is_entry_point": False, "symbol_count": 1, "symbols": []}),
+        ]
+    )
+
+    analyzer = DeadCodeAnalyzer(graph, git_meta_map={})
+    report = analyzer.analyze({"detect_unused_exports": False, "detect_zombie_packages": False})
+
+    paths = {f.file_path for f in report.findings if f.kind.value == "unreachable_file"}
+    assert "unused/dead.nix" in paths
