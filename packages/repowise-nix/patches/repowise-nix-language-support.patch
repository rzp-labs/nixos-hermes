diff -ruN a/tests/unit/ingestion/test_nix_resolver.py b/tests/unit/ingestion/test_nix_resolver.py
--- a/tests/unit/ingestion/test_nix_resolver.py	1969-12-31 17:00:00.000000000 -0700
+++ b/tests/unit/ingestion/test_nix_resolver.py	2026-05-29 01:08:18.127488198 -0700
@@ -0,0 +1,63 @@
+"""Unit tests for Nix import resolution."""
+
+from __future__ import annotations
+
+import networkx as nx
+
+from repowise.core.ingestion.resolvers.context import ResolverContext
+from repowise.core.ingestion.resolvers.nix import resolve_nix_import
+
+
+def _ctx(paths: set[str]) -> ResolverContext:
+    stem_map: dict[str, list[str]] = {}
+    for path in paths:
+        stem = path.rsplit("/", 1)[-1].removesuffix(".nix")
+        stem_map.setdefault(stem, []).append(path)
+    return ResolverContext(path_set=paths, stem_map=stem_map, graph=nx.DiGraph())
+
+
+def test_resolves_relative_nix_module_path() -> None:
+    ctx = _ctx({"hosts/hermes/default.nix", "hosts/hermes/hardware.nix"})
+
+    assert (
+        resolve_nix_import("./hardware.nix", "hosts/hermes/default.nix", ctx)
+        == "hosts/hermes/hardware.nix"
+    )
+
+
+def test_resolves_parent_relative_module_path() -> None:
+    ctx = _ctx({"hosts/hermes/default.nix", "modules/hermes-agent.nix"})
+
+    assert (
+        resolve_nix_import("../../modules/hermes-agent.nix", "hosts/hermes/default.nix", ctx)
+        == "modules/hermes-agent.nix"
+    )
+
+
+def test_resolves_directory_default_nix() -> None:
+    ctx = _ctx({"flake.nix", "hosts/hermes/default.nix"})
+
+    assert resolve_nix_import("./hosts/hermes", "flake.nix", ctx) == "hosts/hermes/default.nix"
+
+
+def test_resolves_callpackage_file_and_directory_forms() -> None:
+    ctx = _ctx({
+        "flake.nix",
+        "packages/tool/package.nix",
+        "packages/wrapper/default.nix",
+    })
+
+    assert resolve_nix_import("./packages/tool/package.nix", "flake.nix", ctx) == "packages/tool/package.nix"
+    assert resolve_nix_import("./packages/wrapper", "flake.nix", ctx) == "packages/wrapper/default.nix"
+
+
+def test_resolves_local_path_flake_input_to_nested_flake() -> None:
+    ctx = _ctx({"flake.nix", "packages/tool/flake.nix"})
+
+    assert resolve_nix_import("path:./packages/tool", "flake.nix", ctx) == "packages/tool/flake.nix"
+
+
+def test_missing_dynamic_path_degrades_without_guessing() -> None:
+    ctx = _ctx({"flake.nix", "packages/tool/default.nix"})
+
+    assert resolve_nix_import("${toolPath}", "flake.nix", ctx) is None
