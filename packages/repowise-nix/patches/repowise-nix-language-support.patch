diff -ruN a/packages/core/src/repowise/core/ingestion/queries/nix.scm b/packages/core/src/repowise/core/ingestion/queries/nix.scm
--- a/packages/core/src/repowise/core/ingestion/queries/nix.scm	1969-12-31 17:00:00.000000000 -0700
+++ b/packages/core/src/repowise/core/ingestion/queries/nix.scm	2026-05-29 01:06:15.727745160 -0700
@@ -0,0 +1,67 @@
+; =============================================================================
+; repowise — Nix symbol and import queries
+;
+; Static support targets first-order evaluator-shaped edges, not full Nix
+; evaluation: module imports, direct imports, selected path-bearing
+; applications, local path flake inputs, and coarse call sites.
+; =============================================================================
+
+; Attribute bindings are the closest useful first-order symbol for NixOS modules:
+; services.foo.enable, systemd.services.bar, flake inputs, let bindings, etc.
+(binding
+  attrpath: (attrpath) @symbol.name
+) @symbol.def
+
+; NixOS module imports = [ ./x.nix ../y.nix ].
+(binding
+  attrpath: (attrpath (identifier) @import.attr)
+  expression: (list_expression
+    (path_expression (path_fragment) @import.module))
+  (#eq? @import.attr "imports")
+) @import.statement
+
+; Direct path imports: import ./x.nix
+(apply_expression
+  function: (variable_expression (identifier) @call.target)
+  argument: (path_expression (path_fragment) @import.module)
+  (#eq? @call.target "import")
+) @import.statement
+
+; callPackage-style selected path applications. The resolver filters supported
+; targets and degrades conservatively for unknown calls.
+(apply_expression
+  function: [
+    (variable_expression (identifier) @nix.call.target)
+    (select_expression) @nix.call.target
+  ]
+  argument: (path_expression (path_fragment) @import.module)
+) @import.statement
+
+; Curried path-bearing applications. Nix represents `f a ./path` as nested
+; apply_expression nodes, so the path argument appears on the outer call while
+; the useful call target is inside the inner function expression.
+(apply_expression
+  function: (apply_expression
+    function: [
+      (variable_expression (identifier) @nix.call.target)
+      (select_expression) @nix.call.target
+    ]
+    argument: (_))
+  argument: (path_expression (path_fragment) @import.module)
+) @import.statement
+
+; Local flake inputs: url = "path:./packages/foo".
+(binding
+  attrpath: (attrpath) @nix.attrpath
+  expression: (string_expression (string_fragment) @import.module)
+  (#match? @nix.attrpath "(^|\.)url$")
+  (#match? @import.module "^path:")
+) @import.statement
+
+; Coarse Nix function/application calls.
+(apply_expression
+  function: [
+    (variable_expression (identifier) @call.target)
+    (select_expression) @call.target
+  ]
+) @call.site
